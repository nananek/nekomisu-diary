# Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
TS_AUTHKEY=tskey-auth-xxxxx

# PostgreSQL password
PG_PASSWORD=change_me_to_something_secure

# WebAuthn Relying Party settings (must match your Tailscale hostname)
RP_ID=diary.your-tailnet.ts.net
RP_ORIGIN=https://diary.your-tailnet.ts.net

# Discord webhook for new post / comment notifications (optional)
DISCORD_WEBHOOK=

# Optional: pin the server image. Defaults to ghcr.io/nananek/nekomisu-diary-server:latest
# SERVER_IMAGE=ghcr.io/nananek/nekomisu-diary-server:sha-abc1234
